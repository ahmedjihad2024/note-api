# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# --- Required ---
# Full MongoDB Atlas connection string.
MONGODB_CONNECTION_STRING=mongodb+srv://user:pass@cluster.mongodb.net/note?retryWrites=true&w=majority
# Base64-encoded 256-bit HMAC secret. Generate one with:
#   openssl rand -base64 32
JWT_SECRET_BASE64=replace-with-output-of-openssl-rand-base64-32

# --- Email (prod uses real SMTP) ---
APP_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=you@example.com
# For Gmail use an App Password, not your account password.
MAIL_PASSWORD=your-smtp-app-password
MAIL_FROM=no-reply@example.com

# --- Frontend / CORS ---
# Comma-separated list of allowed origins.
CORS_ALLOWED_ORIGINS=https://your-frontend.example.com
